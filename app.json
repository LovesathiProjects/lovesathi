{
  "expo": {
    "name": "Lovesathi",
    "slug": "lovesathi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./public/placeholder-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./public/placeholder-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F3EE"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lovesathi.app",
      "infoPlist": {
        "NSCameraUsageDescription": "We need access to your camera for KYC identity verification. This helps keep our community safe and authentic.",
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to upload profile photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./public/placeholder-logo.png",
        "backgroundColor": "#F7F3EE"
      },
      "package": "com.lovesathi.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./public/placeholder-logo.png",
      "bundler": "metro"
    },
    "plugins": []
  }
}
